# Laravel API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000/api/v1

# Allow dashboard access without JWT during local UI-only work (set false to test auth)
VITE_BYPASS_AUTH=false

# Socket.IO (smtp HTTP_PORT — default 3030). Production: https://app.mailvoidr.com
VITE_WS_URL=http://127.0.0.1:3030
